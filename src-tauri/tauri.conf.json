{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoicePartner",
  "version": "1.0.0",
  "identifier": "com.voicepartner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoicePartner",
        "width": 420,
        "height": 720,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "VoicePartner",
    "copyright": "Copyright © 2026 VoicePartner. Licensed under AGPL-3.0.",
    "category": "Productivity",
    "shortDescription": "Your local-first AI voice companion",
    "longDescription": "VoicePartner is a private, local-first desktop companion that listens, talks, and remembers — no cloud, no subscriptions, all AI runs on your machine.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "startMenuFolder": "VoicePartner"
      }
    },
    "resources": {}
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
