{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoicePartner",
  "version": "0.1.0",
  "identifier": "com.voicepartner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VoicePartner",
        "width": 420,
        "height": 720,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [],
    "resources": {}
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
